# Backend Environment Variables
# Copy this file to .env and fill in with your actual values

# ========================================
# Application Configuration
# ========================================
ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# ========================================
# Supabase Configuration
# ========================================
# Get these from your Supabase project settings: https://app.supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ========================================
# Google Gemini AI Configuration
# ========================================
# Get from: https://ai.google.dev/
GEMINI_API_KEY=your-gemini-api-key-here

# ========================================
# Alternative AI Providers (Optional)
# ========================================
GROQ_API_KEY=your-groq-api-key-here
LATE_API_KEY=your-late-api-key-here

# ========================================
# Social Media Integration - PostForMe
# ========================================
POST_FOR_ME_API_KEY=your-postforme-api-key-here

# ========================================
# Stripe Configuration
# ========================================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ========================================
# TikTok Direct API Configuration
# ========================================
# Get from: https://developer.tiktok.com/
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_REDIRECT_URI=http://localhost:8000/api/social/callback

# ========================================
# Frontend & Backend URLs
# ========================================
# Used for CORS, redirects, and OAuth callbacks
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# ========================================
# OAuth State Secret
# ========================================
# Used for securing OAuth state during social media auth flows
# Generate a random key: python -c "import secrets; print(secrets.token_urlsafe(32))"
STATE_SECRET_KEY=your-random-secret-key-here

# ========================================
# Image Generation - Unsplash Configuration (Optional)
# ========================================
UNSPLASH_APP_ID=your-unsplash-app-id
UNSPLASH_SECRET_KEY=your-unsplash-secret-key
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# ========================================
# Image Generation - Runware Configuration (Optional)
# ========================================
RUNWARE_DEV_KEY=your-runware-dev-key-here

# ========================================
# Logging Configuration (Optional)
# ========================================
LOG_LEVEL=INFO
