# Frontend Environment Variables
# Copy this file to .env.local and fill in with your actual values for local development

# ========================================
# API Configuration
# ========================================
# Backend API endpoint - Update based on environment
NEXT_PUBLIC_API_URL=http://localhost:8000

# Base URL for redirects and canonical tags
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ========================================
# App Configuration
# ========================================
NEXT_PUBLIC_APP_NAME=Radius

# ========================================
# Supabase Configuration
# ========================================
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=your-public-key-here

# ========================================
# Stripe Configuration (for billing)
# ========================================
# Publishable key (can be public)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Secret key (keep private - only in server-side code or backend)
STRIPE_SECRET_KEY=sk_test_your_key_here

# ========================================
# Stripe Webhook
# ========================================
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ========================================
# Feature Flags / Environment
# ========================================
# Optional: Set to 'production' in production environment
NEXT_PUBLIC_ENV=development

# Sentry Configuration (optional - for error tracking)
# NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
